# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
API_BASE_URL=https://api.hashpay.io

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://hashpay:password@localhost:5432/hashpay_db"

# ── Redis (Bull queues + caching) ─────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d

# ── Sui (PRIMARY CHAIN) ───────────────────────────────────────
SUI_NETWORK=mainnet                          # mainnet | testnet | devnet
SUI_RPC_URL=https://fullnode.mainnet.sui.io  # optional override
SUI_PACKAGE_ID=0xYOUR_DEPLOYED_PACKAGE_ID
SUI_TREASURY_ADDRESS=0xYOUR_TREASURY_ADDRESS
SUI_BACKEND_ADDRESS=0xYOUR_BACKEND_HOT_WALLET
SUI_BACKEND_PRIVATE_KEY=suiprivkey1...       # Ed25519, bech32 encoded
SUI_BACKEND_CAP_ID=0xBACKEND_CAP_OBJECT_ID
SUI_TREASURY_CAP_ID=0xTREASURY_CAP_OBJECT_ID
SUI_RATE_STORE_ID=0xRATE_STORE_OBJECT_ID
SUI_BACKEND_SECP256K1_PUBKEY=02...           # 33-byte compressed hex (for quote signing)
SUI_BACKEND_SECP256K1_PRIVKEY=...            # hex private key for signing quotes

# ── Aptos (LEGACY — keep for existing orders) ─────────────────
APTOS_NETWORK=mainnet
APTOS_NODE_URL=https://fullnode.mainnet.aptoslabs.com/v1
APTOS_INDEXER_URL=https://indexer.mainnet.aptoslabs.com/v1/graphql
HASHPAY_MODULE_ADDRESS=0xYOUR_APTOS_MODULE_ADDRESS
TREASURY_PRIVATE_KEY=your_aptos_treasury_private_key

# ── Ethereum / EVM ────────────────────────────────────────────
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
ETH_PRIVATE_KEY=your_ethereum_treasury_private_key
HASHPAY_EVM_CONTRACT=0xYOUR_EVM_CONTRACT_ADDRESS

# ── Fiat Payout — Afriex (NGN, GHS, KES) ─────────────────────
AFRIEX_API_KEY=your_afriex_api_key
AFRIEX_WEBHOOK_SECRET=your_afriex_webhook_secret

# ── Fiat Payout — Opay (NGN — fastest for Nigerian banks) ─────
OPAY_MERCHANT_ID=your_opay_merchant_id
OPAY_PUBLIC_KEY=your_opay_public_key
OPAY_PRIVATE_KEY=your_opay_private_key

# ── Fiat Payout — Flipeet (XOF, XAF, GHS, NGN) ───────────────
FLIPEET_API_KEY=your_flipeet_api_key
FLIPEET_WEBHOOK_SECRET=your_flipeet_webhook_secret

# ── Fiat Payout — Flutterwave (legacy fallback) ───────────────
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxx

# ── Fiat Payout — Paystack (legacy fallback) ──────────────────
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# ── KYC Provider (Smile ID) ───────────────────────────────────
SMILE_ID_PARTNER_ID=your_smile_id_partner_id
SMILE_ID_API_KEY=your_smile_id_api_key

# ── Oracle / Price Feeds ──────────────────────────────────────
PYTH_ENDPOINT=https://hermes.pyth.network
COINGECKO_API_KEY=your_coingecko_api_key

# ── Airtime / Data (Africa's Talking) ─────────────────────────
AT_USERNAME=your_africastalking_username
AT_API_KEY=your_africastalking_api_key

# ── Notifications ─────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ── Security ──────────────────────────────────────────────────
ENCRYPTION_KEY=32_char_aes256_encryption_key_here
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
