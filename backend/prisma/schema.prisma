// HashPay Global — Prisma Schema
// Run: npx prisma migrate dev --name add_wallet_system

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  TREASURY
}

enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum KycLevel {
  NONE
  BASIC
  FULL
}

enum EscrowStatus {
  DEPOSITING
  PENDING_PAYOUT
  COMPLETED
  PAYOUT_FAILED
  REFUNDED
  CANCELLED
}

enum AirtimeStatus {
  PENDING
  COMPLETED
  FAILED
}

enum WalletTxType {
  CREDIT
  DEBIT
}

enum WalletTxStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum WalletTxSource {
  CRYPTO_DEPOSIT   // Paycrest order settled → NGN credited
  INTERNAL_TRANSFER_IN
  INTERNAL_TRANSFER_OUT
  WITHDRAWAL       // User cashed out to bank
  REVERSAL
}

// ── Models ───────────────────────────────────────────────────

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String
  fullName         String
  role             UserRole  @default(USER)

  // Wallet addresses
  aptosAddress     String?   @unique
  evmAddress       String?   @unique
  suiAddress       String?   @unique   // ← NEW: Sui wallet address

  // Bank details (encrypted at application layer)
  bankCode         String?
  bankName         String?
  bankAccountNumber String?
  bankAccountName  String?

  // Preferred payout currency
  preferredCurrency String?  @default("NGN")  // ← NEW: NGN | GHS | KES | XOF | XAF

  // HashPay internal account
  hashpayAccountNumber String?  @unique  // e.g. "4031285796"

  // Paystack / Paycrest virtual bank account
  virtualAccountNumber String?
  virtualBankName      String?
  virtualBankCode      String?
  virtualAccountRef    String?  // provider reference

  // KYC
  kycStatus        KycStatus @default(NONE)
  kycLevel         KycLevel  @default(NONE)
  kycJobId         String?

  // Relations
  escrowOrders     EscrowOrder[]
  airtimeTransactions AirtimeTransaction[]
  swapHistory      SwapRecord[]
  wallet           Wallet?
  sentTransfers    WalletTransaction[] @relation("SentTransfers")
  receivedTransfers WalletTransaction[] @relation("ReceivedTransfers")

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([aptosAddress])
  @@index([evmAddress])
  @@index([suiAddress])
  @@index([hashpayAccountNumber])
  @@map("users")
}

// ── Wallet (one per user) ────────────────────────────────────

model Wallet {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])

  ngnBalance   Decimal  @default(0) @db.Decimal(18, 2)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions WalletTransaction[]

  @@map("wallets")
}

// ── Wallet Transaction Ledger ────────────────────────────────

model WalletTransaction {
  id              String          @id @default(uuid())
  walletId        String
  wallet          Wallet          @relation(fields: [walletId], references: [id])

  type            WalletTxType
  source          WalletTxSource
  status          WalletTxStatus  @default(PENDING)

  amount          Decimal         @db.Decimal(18, 2)
  balanceBefore   Decimal         @db.Decimal(18, 2)
  balanceAfter    Decimal         @db.Decimal(18, 2)

  // For internal transfers
  senderId        String?
  sender          User?           @relation("SentTransfers", fields: [senderId], references: [id])
  recipientId     String?
  recipient       User?           @relation("ReceivedTransfers", fields: [recipientId], references: [id])

  // For crypto deposits (Paycrest)
  paycrestOrderId String?         @unique
  cryptoAsset     String?         // 'USDC' | 'USDT'
  cryptoAmount    Decimal?        @db.Decimal(18, 8)
  exchangeRate    Decimal?        @db.Decimal(18, 4)

  // For withdrawals
  bankAccountNumber String?
  bankName          String?

  reference       String?         @unique
  description     String?
  metadata        Json?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([walletId])
  @@index([senderId])
  @@index([recipientId])
  @@index([paycrestOrderId])
  @@index([status])
  @@map("wallet_transactions")
}

model EscrowOrder {
  id             String       @id @default(uuid())

  // On-chain data (Aptos OR Sui — one will be set)
  aptosEventSeq  String?      @unique   // Aptos event sequence (idempotency key)
  suiOrderId     String?      @unique   // Sui order_id bytes as hex string
  txHash         String
  userAddress    String
  asset          String                 // 'USDC' | 'USDT' | 'ETH' | 'SUI'
  amountRaw      String                 // u64 as string (on-chain decimals)

  // ── NEW: Sui-specific fields ──────────────────────────────
  recordId       String?                // Sui EscrowRecord object ID
  currencyOut    String?  @default("NGN") // 'NGN' | 'GHS' | 'KES' | 'XOF' | 'XAF'
  amountOut      Float?                 // locked fiat amount from quote
  timeoutEpoch   BigInt?                // Sui epoch after which user can self-refund
  chain          String?  @default("aptos") // 'aptos' | 'sui' | 'evm'

  // Fiat payout
  ngnAmount      Float?
  payoutRef      String?                // Provider payout reference
  payoutProvider String?                // 'afriex' | 'opay' | 'flipeet' | 'flutterwave' | 'paystack'

  // Status
  status         EscrowStatus @default(DEPOSITING)
  failureReason  String?

  // Relations
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])

  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([userAddress])
  @@index([status])
  @@index([payoutRef])
  @@index([recordId])
  @@index([currencyOut])
  @@map("escrow_orders")
}

model SwapRecord {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  assetIn     String
  assetOut    String
  amountIn    Float
  amountOut   Float
  rate        Float
  slippageBps Int      @default(50)
  txHash      String?
  chain       String?  @default("sui")   // ← NEW
  status      String   @default("PENDING")

  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("swap_records")
}

model AirtimeTransaction {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])

  phoneNumber String
  amount      Float
  currency    String        @default("NGN")
  payAsset    String        @default("USDC")
  cryptoCost  Float
  reference   String?
  status      AirtimeStatus @default(PENDING)

  createdAt   DateTime      @default(now())

  @@index([userId])
  @@map("airtime_transactions")
}

model PriceSnapshot {
  id        String   @id @default(uuid())
  asset     String
  usdPrice  Float
  ngnRate   Float
  ghsRate   Float?   // ← NEW
  kesRate   Float?   // ← NEW
  xofRate   Float?   // ← NEW
  xafRate   Float?   // ← NEW
  source    String   @default("pyth")
  chain     String?  @default("sui")
  createdAt DateTime @default(now())

  @@index([asset, createdAt])
  @@map("price_snapshots")
}

model ReconciliationLog {
  id              String   @id @default(uuid())
  runAt           DateTime @default(now())
  chain           String   @default("sui")   // ← NEW
  onChainBalance  Float
  dbBalance       Float
  discrepancy     Float
  status          String   // 'OK' | 'DISCREPANCY'
  notes           String?

  @@map("reconciliation_logs")
}

// ── NEW: Provider health tracking ────────────────────────────

model ProviderHealthLog {
  id           String   @id @default(uuid())
  provider     String   // 'afriex' | 'opay' | 'flipeet'
  currency     String   // 'NGN' | 'GHS' | 'KES'
  success      Boolean
  latencyMs    Int?
  errorMessage String?
  checkedAt    DateTime @default(now())

  @@index([provider, currency, checkedAt])
  @@map("provider_health_logs")
}

// ── NEW: Dead-letter queue tracking ──────────────────────────

model DeadLetterOrder {
  id            String   @id @default(uuid())
  orderId       String   @unique
  recordId      String?  // Sui EscrowRecord object ID
  reason        String
  retryCount    Int      @default(0)
  resolvedAt    DateTime?
  resolvedBy    String?
  createdAt     DateTime @default(now())

  @@map("dead_letter_orders")
}
